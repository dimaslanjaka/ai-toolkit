{
  "name": "@dimaslanjaka/ai-toolkit",
  "version": "1.0.0",
  "description": "AI toolkit and utilities for opencode integration, LLM providers, and AI-powered development workflows",
  "keywords": [
    "ai",
    "toolkit",
    "opencode",
    "llm",
    "openai",
    "ollama",
    "chatgpt",
    "copilot"
  ],
  "author": "dimaslanjaka <dimaslanjaka@gmail.com> (https://webmanajemen.com)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "gulp",
    "build:ts": "gulp buildTs",
    "build:copy": "gulp copySql",
    "build:rollup": "gulp buildRollup",
    "build:declaration": "gulp buildDeclarations",
    "build:web": "gulp buildWeb",
    "clean": "npx -y rimraf tmp/dist dist",
    "dev:web": "vite --config vite.config.mjs",
    "pack": "npx -y tarball-packer --yarn --filename ai-toolkit --normalize-resolutions",
    "prepare": "husky",
    "preview:web": "vite preview --config vite.config.mjs",
    "test": "node --disable-warning=ExperimentalWarning --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --config jest.config.mjs",
    "jest": "node --disable-warning=ExperimentalWarning --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --config jest.config.mjs",
    "update:ncu": "npx -y npm-check-updates -u"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "check-proxy": "./dist/proxy/checker.runner.cjs",
    "opc-check-proxy": "./dist/proxy/opencode-checker.runner.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    ".puppeteerrc.cjs"
  ],
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@babel/parser": "^7.29.7",
