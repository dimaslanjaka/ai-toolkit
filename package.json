{
  "name": "@dimaslanjaka/ai-toolkit",
  "version": "1.0.0",
  "description": "AI toolkit and utilities for opencode integration, LLM providers, and AI-powered development workflows",
  "keywords": [
    "ai",
    "toolkit",
    "opencode",
    "llm",
    "openai",
    "ollama",
    "chatgpt",
    "copilot"
  ],
  "author": "dimaslanjaka <dimaslanjaka@gmail.com> (https://webmanajemen.com)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build-declaration": "tsc -p tsconfig.dts.json",
    "build": "rollup -c && npm run build-declaration",
    "clean": "npx -y rimraf tmp dist",
    "pack": "npx -y tarball-packer --yarn --filename ai-toolkit --normalize-resolutions",
    "prepare": "husky",
    "test": "node --disable-warning=ExperimentalWarning --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --config jest.config.mjs",
    "update:ncu": "npx -y npm-check-updates -u"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    ".puppeteerrc.cjs"
  ],
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@heyputer/puter.js": "^2.5.1",
    "@opencode-ai/plugin": "^1.16.0",
    "@qwen-code/qwen-code": "^0.15.11",
    "axios": "^1.17.0",
    "binary-collections": "^2.0.15",
    "cors": "^2.8.6",
    "cross-spawn": "https://github.com/dimaslanjaka/node-cross-spawn/raw/private/release/cross-spawn.tgz",
    "crypto-js": "^4.2.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.5",
    "fuse.js": "^7.3.0",
    "glob": "^13.0.6",
    "jsonc-parser": "3.3.1",
    "ollama": "^0.6.3",
    "puppeteer": "^25.0.4",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sbg-utility": "^2.0.11",
    "upath": "^3.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-syntax-import-assertions": "^7.28.6",
    "@babel/preset-typescript": "^7.29.0",
    "@dimaslanjaka/eslint-base-config": "^1.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9",
    "@jest/globals": "^30.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/babel__core": "^7",
    "@types/babel__traverse": "^7",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4",
    "@types/express": "^5",
    "@types/fs-extra": "^11",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint": "^9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "16.2.7",
    "openai": "^6.41.0",
    "prettier": "3.8.3",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-twig": "^1.0.1",
    "rollup": "^4.60.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.3",
    "unrun": "^0.3.0",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "cross-spawn": "https://github.com/dimaslanjaka/node-cross-spawn/raw/645f2ab49603b55fa9609e54a43a76dfa6caa114/release/cross-spawn.tgz",
    "binary-collections": "https://github.com/dimaslanjaka/bin/raw/3a5ceeab075f0d687bdd3c30c274d21aaa7b39a3/releases/bin.tgz",
