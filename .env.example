MYSQL_USER_PRODUCTION="your_production_user"
MYSQL_PASS_PRODUCTION="your_production_password"
MYSQL_HOST_PRODUCTION="your_production_host"
MYSQL_DBNAME_PRODUCTION=your_production_dbname

MYSQL_USER=your_local_user
MYSQL_PASS=your_local_password
MYSQL_DBNAME=your_local_dbname
MYSQL_HOST=127.0.0.1

# Chat frontend development server and API backend.
VITE_HOSTNAME=dev.example.com
VITE_PORT=5173
VITE_BACKEND_HOSTNAME_DEV=127.0.0.1:5758
VITE_BACKEND_HOSTNAME_PROD=api.example.com

# Local HTTPS is enabled by default and shared by Vite and Express.
OPENAI_SERVER_HTTPS=true
OPENAI_SERVER_HTTPS_KEY_FILE=.cert/dev.pem
OPENAI_SERVER_HTTPS_CERT_FILE=.cert/cert.pem
