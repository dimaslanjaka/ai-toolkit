{
  "[shellscript]": {
    "files.eol": "\n",
    "editor.defaultColorDecorators": "never",
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[html]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.organizeImports": "never"
    },
    "editor.suggest.insertMode": "replace"
  },
  "[json]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.organizeImports": "never"
    },
    "editor.quickSuggestions": {
      "strings": true
    },
    "editor.suggest.insertMode": "replace"
  },
  "[jsonc]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.organizeImports": "never"
    },
    "editor.quickSuggestions": {
      "strings": true
    },
    "editor.suggest.insertMode": "replace"
  },
  "[njk]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.organizeImports": "never"
    },
    "editor.suggest.insertMode": "replace"
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never"
    },
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": false,
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[twig]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "autopep8.args": ["--ignore", "E401,E402,E211,E501"],
  "code-runner.clearPreviousOutput": true,
  "code-runner.cwd": "${workspaceFolder}",
  "code-runner.executorMapByGlob": {
    "*.electron.js": "cross-env-shell NODE_ENV=development electron -r ts-node/register",
    "*.mjs": "node --no-warnings=ExperimentalWarning",
    "*.py": "py -u",
    "*.test.{cjs,js,mjs,ts}": "npm test --",
    "*Test.php": "phpunit --debug --testdox --colors=always",
    "electron-*.ts": "cross-env-shell NODE_ENV=development electron -r ts-node/register",
    "rollup.*.{js,cjs,mjs,ts}": "rollup -c",
    "*.sh": "sh",
    "*.bat": "cmd /c",
    "*.ts": "node --no-warnings=ExperimentalWarning --loader ts-node/esm"
  },
  "code-runner.ignoreSelection": true,
  "code-runner.respectShebang": false,
  "code-runner.runInTerminal": true,
  "code-runner.saveAllFilesBeforeRun": true,
  "code-runner.saveFileBeforeRun": true,
  "debug.terminal.clearBeforeReusing": true,
  "debug.javascript.terminalOptions": {
    "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**", "**/node_modules/.vite-temp/**"]
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "never",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.ts": "never",
    "source.addMissingImports.ts": "never",
    "source.removeUnused.ts": "never",
    "source.removeUnusedImports": "never",
    "source.sort.json": "never",
    "source.sortImports": "never"
  },
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "eslint.debug": true,
  "eslint.enable": true,
  "eslint.format.enable": true,
  "eslint.ignoreUntitled": true,
  "eslint.lintTask.enable": true,
  "eslint.probe": [
    "astro",
    "civet",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "twig",
    "css",
    "glimmer-js",
    "glimmer-ts",
    "svelte",
    "nunjucks"
  ],
  "eslint.validate": [
    "astro",
    "civet",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "twig",
    "css",
    "glimmer-js",
    "glimmer-ts",
    "svelte",
    "nunjucks"
  ],
  "eslint.useESLintClass": true,
  "eslint.useFlatConfig": true,
  "files.autoSave": "onWindowChange",
  "files.watcherExclude": {
    "**/.cache/**": true,
    "**/.idea/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/.yarn/**": true,
    "**/dist/**": true,
    "**/profiles/**": true,
    "**/config/**": true,
    "**/databases/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/out/**": true,
    "**/coverage/**": true,
    "src/database.sqlite*": true
  },
  "git.autoStash": true,
  "git.useCommitInputAsStashMessage": true,
  "git.repositoryScanIgnoredFolders": ["node_modules", ".deploy_git", "tmp", ".cache"],
  "intelephense.environment.phpVersion": "8.0.0",
  "intelephense.diagnostics.enable": true,
  "intelephense.diagnostics.run": "onSave",
  "intelephense.environment.includePaths": ["./src", "./vendor", "${workspaceFolder}/tests"],
  "intelephense.files.exclude": [
    "**/.DS_Store/**",
    "**/.git/**",
    "**/.history/**",
    "**/.hg/**",
    "**/.svn/**",
    "**/CVS/**",
    "**/bower_components/**",
    "**/node_modules/**"
  ],
  "intelephense.maxMemory": 4000,
  "intelephense.references.exclude": [],
  "intelephense.rename.exclude": [],
  "isort.args": ["--profile", "black"],
  "js/ts.updateImportsOnPaste.enabled": false,
  "js/ts.implicitProjectConfig.checkJs": false,
  "js/ts.implicitProjectConfig.experimentalDecorators": true,
  "js/ts.implicitProjectConfig.module": "ESNext",
  "remoteHub.gitProtocol": "http",
  "remoteHub.richNavigation.enabled": true,
  "sftp.debug": true,
  "sftp.printDebugLog": true,
  "search.exclude": {
    "**/.cache/**": true,
    "**/.DS_Store": true,
    "**/.git/**": true,
    "**/.hg/**": true,
    "**/.idea/**": true,
    "**/.svn/**": true,
    "**/.venv/**": true,
    "**/.yarn/**": true,
    "**/backups/**": true,
    "**/bas/**": true,
    "**/config/**": true,
    "**/coverage/**": true,
    "**/data/**": true,
    "**/databases/**": true,
    "**/dist/**": true,
    "**/hash.txt": true,
    "**/node_modules/**": true,
    "**/profiles/**": true,
    "**/Thumbs.db": true,
    "**/vendor/**": true,
    "**/venv/**": true
  },
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.env.linux": {
    "DEBUG_PKG": "1",
    "ESLINT_USE_FLAT_CONFIG": "true",
    "NUITKA_CACHE_DIR": "${workspaceFolder}/tmp/nuitka-cache",
    "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/usr/lib/wsl/lib:${workspaceFolder}/bin:${workspaceFolder}/node_modules/.bin:${workspaceFolder}/vendor/bin",
    "PHP_CS_FIXER_IGNORE_ENV": "1",
    "PUPPETEER_SKIP_DOWNLOAD": "true"
  },
  "terminal.integrated.env.windows": {
    "DEBUG_PKG": "1",
    "ESLINT_USE_FLAT_CONFIG": "true",
    "NUITKA_CACHE_DIR": "${workspaceFolder}\\tmp\\nuitka-cache",
    "PATH": "${env:LOCALAPPDATA}\\nvm;C:\\nvm4w\\nodejs;C:\\Program Files\\Git\\cmd;C:\\Program Files\\Git\\usr\\bin;${env:PATH};${workspaceFolder}\\node_modules\\.bin;${workspaceFolder}\\bin;${workspaceFolder}\\vendor\\bin;C:\\laragon\\bin\\mysql\\mysql-8.4.3-winx64\\bin;${env:LOCALAPPDATA}\\Programs\\Ollama",
    "PHP_CS_FIXER_IGNORE_ENV": "1",
    "PUPPETEER_SKIP_DOWNLOAD": "true",
    "WORKSPACE_FOLDER": "${workspaceFolder}"
  },
  "terminal.integrated.profiles.windows": {
    "Cygwin": {
      "args": ["--login", "-i"],
      "env": {
        "CHERE_INVOKING": "1"
      },
      "path": "C:\\cygwin64\\bin\\bash.exe"
    },
    "Command Prompt": {
      "args": [],
      "icon": "terminal-cmd",
      "path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"]
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "PowerShell": {
      "icon": "terminal-powershell",
      "source": "PowerShell"
    },
    "Short PowerShell": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "function prompt { \"[$((Get-Item .).Name)]> \" }"],
      "icon": "terminal-powershell"
    },
    "Short Command Prompt": {
      "path": ["${env:windir}\\System32\\cmd.exe"],
      "args": ["/k", "prompt $p$_$g"],
      "icon": "terminal-cmd"
    },
    "PowerShell 7": {
      "path": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
      "icon": "terminal-powershell"
    },
    "Short PowerShell 7": {
      "path": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
      "args": [
        "-NoExit",
        "-Command",
        "function prompt { Write-Host '[' -NoNewline -ForegroundColor DarkGray; Write-Host (Split-Path -Leaf (Get-Location)) -NoNewline -ForegroundColor Cyan; Write-Host ']> ' -NoNewline -ForegroundColor DarkGray; return ' ' }"
      ],
      "icon": "terminal-powershell"
    },
    "Oh My Posh": {
      "path": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
      "args": [
        "-NoExit",
        "-Command",
        "$init = $null; foreach ($candidate in @('${workspaceFolder}/scripts/OhMyPoshInit.ps1','${workspaceFolder}/node_modules/@dimaslanjaka/eslint-base-config/scripts/OhMyPoshInit.ps1')) { if (Test-Path $candidate) { $init = $candidate; break } }; if ($init) { & $init } else { oh-my-posh init pwsh | Invoke-Expression }"
      ],
      "icon": "terminal-powershell"
    }
  },
  "testing.displayedCoveragePercent": "minimum",
  "testing.followRunningTest": true,
  "shellformat.useEditorConfig": true,
  "shellformat.effectLanguages": [
    "shellscript",
    "dockerfile",
    "dotenv",
    "hosts",
    "jvmoptions",
    "ignore",
    "gitignore",
    "properties",
    "spring-boot-properties",
    "azcli",
    "bats"
  ],
  "[php]": {
    "editor.defaultFormatter": "junstyle.php-cs-fixer"
  },
  "php-cs-fixer.executablePath": "${workspaceFolder}/vendor/bin/php-cs-fixer.phar",
  "php-cs-fixer.executablePathWindows": "${workspaceFolder}/vendor/bin/php-cs-fixer.bat",
  "php-cs-fixer.onsave": false,
  "php-cs-fixer.rules": "@PSR12",
  "php-cs-fixer.config": ".php-cs-fixer.php;.php-cs-fixer.dist.php;.php_cs;.php_cs.dist",
  "php-cs-fixer.exclude": [
    "*/vendor/*",
    "*/bas/*",
    "*/backups/*",
    "*/data/*",
    "*/dist/*",
    "*/node_modules/*",
    "*/profiles/*",
    "*/config/*",
    "*/databases/*",
    "**/vscode-plugins/**"
  ],
  "php-cs-fixer.configFile": "./.php-cs-fixer.dist.php",
  "php-cs-fixer.executable": "./vendor/bin/php-cs-fixer.bat",
  "php-cs-fixer.autoFixBySemicolon": false,
  "php-cs-fixer.allowRisky": true,
  "php-cs-fixer.autoFixByBracket": false,
  "php-cs-fixer.ignorePHPVersion": true,
  "phpcs.enable": true,
  "phpcs.executablePath": "./vendor/bin/phpcs.bat",
  "phpcs.standard": "./phpcs.xml",
  "phpcs.ignorePatterns": [
    "*/vendor/*",
    "*/bas/*",
    "*/backups/*",
    "*/data/*",
    "*/dist/*",
    "*/node_modules/*",
    "*/profiles/*",
    "*/config/*",
    "*/databases/*",
    "**/vscode-plugins/**"
  ],
  "git.openRepositoryInParentFolders": "always",
  "git.autofetch": "all",
  "git.ignoreLimitWarning": true,
  "git.autoRepositoryDetection": "openEditors",
  "scm.repositories.sortOrder": "name",
  "scm.alwaysShowRepositories": true,
  "github.copilot.chat.localeOverride": "en",
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.enableRetryAfterFilteredResponse": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "chat.agent.maxRequests": 50,
  "github.copilot.chat.summarizeAgentConversationHistory.enabled": false,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.suggest.enabled": false,
  "terminal.integrated.shellIntegration.quickFixEnabled": true,
  "git.allowNoVerifyCommit": true,
  "intelephense.format.braces": "allman",
  "intelephense.format.enable": false,
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python-envs.workspaceSearchPaths": ["./**/venv", "./**/.venv"],
  "python.terminal.activateEnvironment": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.diagnosticsSource": "Pyright",
  "python.analysis.inlayHints.pytestParameters": true,
  "python.createEnvironment.contentButton": "show",
  "python.envFile": "${workspaceFolder}/.env",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "python.testing.autoTestDiscoverOnSavePattern": "**/*test*.py",
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.debugPort": 8467,
  "python.testing.promptToConfigure": true,
  "python.useEnvironmentsExtension": false,
  "python.testing.pytestArgs": [
    "-ra",
    "-v",
    "-s",
    "--cov=src",
    "--cov=data",
    "--cov=django_backend",
    "--cov-report=term-missing",
    "--cov-report=html:coverage/pytest",
    "-k",
    "*test*.py",
    "./tests"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "evenBetterToml.formatter.trailingNewline": true,
  "evenBetterToml.formatter.crlf": false,
  "evenBetterToml.formatter.columnWidth": 88,
  "evenBetterToml.formatter.allowedBlankLines": 2,
  "python.languageServer": "Pylance",
  "python.terminal.useEnvFile": true,
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.rateLimitAutoSwitchToAuto": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": true
  },
  "chat.mcp.apps.enabled": true,
  "chat.mcp.access": "all",
  "chat.mcp.gallery.enabled": true,
  "chatgpt.gpt3.provider": "Ollama",
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.serverSampling": {
    "php-proxy-hunter/.vscode/mcp.json: ollama-ai": {
      "allowedModels": [
        "copilot/auto",
        "copilotcli/claude-haiku-4.5",
        "claude-code/claude-haiku-4.5",
        "copilot/claude-haiku-4.5",
        "copilot/gemini-2.5-pro",
        "copilot/gemini-3-flash-preview",
        "copilot/gemini-3.1-pro-preview",
        "copilot/gpt-4.1",
        "copilotcli/gpt-4.1",
        "copilot/gpt-4o",
        "copilot/gpt-5-mini",
        "copilotcli/gpt-5-mini",
        "copilot/gpt-5.2",
        "copilotcli/gpt-5.2",
        "copilot/gpt-5.2-codex",
        "copilotcli/gpt-5.2-codex",
        "copilotcli/gpt-5.3-codex",
        "copilot/gpt-5.4-mini",
        "copilotcli/gpt-5.4-mini",
        "copilot/grok-code-fast-1",
        "copilot/oswe-vscode-prime"
      ]
    }
  },
  "debug.javascript.codelens.npmScripts": "never",
  "editor.codeLens": false,
  "merge-conflict.codeLens.enabled": true,
  "python.analysis.referencesCodeLens": false,
  "js/ts.referencesCodeLens.showOnAllFunctions": false,
  "js/ts.referencesCodeLens.enabled": false,
  "js/ts.implementationsCodeLens.showOnInterfaceMethods": false,
  "js/ts.implementationsCodeLens.showOnAllClassMethods": false,
  "js/ts.implementationsCodeLens.enabled": false,
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,
  "chat.agent.enabled": true,
  "chat.agent.networkFilter": false,
  "chat.checkpoints.showFileChanges": true
}
